{
  "name": "@statewalker/ai-agent.core",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./state": "./src/state/index.ts",
    "./models": "./src/models/index.ts",
    "./runtime": "./src/runtime/index.ts",
    "./tools": "./src/tools/index.ts"
  },
  "files": [
    "dist/**",
    "src/**"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:",
    "@ai-sdk/google": "catalog:",
    "@ai-sdk/mcp": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "@ai-sdk/provider": "catalog:",
    "@modelcontextprotocol/sdk": "catalog:",
    "@statewalker/shared-baseclass": "catalog:",
    "@statewalker/shared-ids": "catalog:",
    "@statewalker/webrun-files": "catalog:",
    "@statewalker/webrun-files-composite": "catalog:",
    "ai": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@statewalker/webrun-files-mem": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/statewalker/statewalker-ai.git",
    "directory": "packages/ai-agent"
  }
}
