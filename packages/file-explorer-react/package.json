{
  "name": "@statewalker/file-explorer-react",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "File-explorer renderer fragment: tree, list, drag-and-drop, context menu, navigation breadcrumbs, search panel.",
  "homepage": "https://github.com/statewalker/statewalker-workbench",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/statewalker/statewalker-workbench.git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./fragment": "./src/fragment.ts",
    "./styles": "./src/styles.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@json-render/react": "0.18.0",
    "@statewalker/shared-baseclass": "catalog:",
    "@statewalker/shared-commands": "catalog:",
    "@statewalker/shared-registry": "catalog:",
    "@statewalker/core-react": "workspace:*",
    "@statewalker/dock": "workspace:*",
    "@statewalker/dock-react": "workspace:*",
    "@statewalker/file-explorer": "workspace:*",
    "@statewalker/catalog-registry": "workspace:*",
    "@statewalker/mime.core": "workspace:*",
    "@statewalker/shadcn-react": "workspace:*",
    "@statewalker/spec-store": "workspace:*",
    "@statewalker/shared-slots": "workspace:*",
    "@statewalker/webrun-files": "workspace:*",
    "@statewalker/workspace": "workspace:*",
    "lucide-react": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@statewalker/webrun-files-mem": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
