{
  "name": "@statewalker/shared-react-shadcn",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "shadcn/ui renderers for shared-react: default component set built on Radix UI and Tailwind.",
  "homepage": "https://github.com/statewalker/statewalker-workbench",
  "author": {
    "name": "Mikhail Kotelnikov",
    "email": "mikhail.kotelnikov@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/statewalker/statewalker-workbench.git"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "lint": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@statewalker/shared-adapters": "workspace:*",
    "@statewalker/shared-react": "workspace:*",
    "@statewalker/shared-registry": "workspace:*",
    "@statewalker/shared-views": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "radix-ui": "^1.1.3",
    "react": "catalog:",
    "react-resizable-panels": "catalog:",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "rimraf": "catalog:",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
