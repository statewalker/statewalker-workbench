{
  "name": "@statewalker/shared-react-shadcn",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "shadcn/ui renderers for shared-react: default component set built on Radix UI and Tailwind.",
  "homepage": "https://github.com/statewalker/statewalker-workbench",
  "author": {
    "name": "Mikhail Kotelnikov",
    "email": "mikhail.kotelnikov@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/statewalker/statewalker-workbench.git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./components": "./src/components/index.ts",
    "./icons": "./src/icons/index.ts",
    "./layouts": "./src/layouts/index.ts",
    "./renderers": "./src/renderers/index.ts",
    "./routing": "./src/routing/index.ts",
    "./init-views": "./src/init-views.ts",
    "./init-common-views": "./src/init-common-views.ts",
    "./init-ai-model-views": "./src/init-ai-model-views.ts",
    "./theme.css": "./src/layouts/theme.css",
    "./index.css": "./src/index.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@statewalker/shared-adapters": "catalog:",
    "@statewalker/shared-react": "workspace:*",
    "@statewalker/shared-registry": "catalog:",
    "@statewalker/shared-views": "workspace:*",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "lucide-react": "catalog:",
    "radix-ui": "catalog:",
    "react": "catalog:",
    "react-resizable-panels": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "rimraf": "catalog:",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
