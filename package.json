{
  "name": "@repo/shared-react-shadcn",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./components": "./src/components/index.ts",
    "./renderers": "./src/renderers/index.ts",
    "./init": "./src/init-common-views.ts",
    "./init-ai-models": "./src/init-ai-model-views.ts",
    "./layouts": "./src/layouts/index.ts",
    "./theme.css": "./src/layouts/theme.css",
    "./lib/utils": "./src/lib/utils.ts",
    "./routing": "./src/routing/hash-routing.ts"
  },
  "files": [
    "dist/**",
    "src/**"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "build:browser": "vite build --config vite.config.lib.ts && node ../../scripts/generate-browser-package-json.mjs . && cp src/layouts/theme.css dist-browser/theme.css",
    "clean": "rm -rf dist",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "dependencies": {
    "@repo/shared-react": "workspace:*",
    "@repo/shared-views": "workspace:*",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.475.0",
    "radix-ui": "^1.4.2",
    "react-resizable-panels": "catalog:",
    "tailwind-merge": "^2.2.0",
    "@statewalker/shared-adapters": "workspace:*",
    "@statewalker/shared-registry": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^3.4.0 || ^4.0.0"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:",
    "tailwindcss": "catalog:"
  }
}
