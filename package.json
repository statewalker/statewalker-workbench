{
  "name": "@repo/shared-react",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./hooks": "./src/hooks/index.ts",
    "./component-registry": "./src/component-registry/index.ts",
    "./dock": "./src/dock/index.ts",
    "./dock-hooks": "./src/dock-hooks/index.ts",
    "./shell-hooks": "./src/shell-hooks/index.ts",
    "./icons": "./src/icons/index.ts",
    "./app-context": "./src/app-context.tsx"
  },
  "files": [
    "dist/**",
    "src/**"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "build:browser": "vite build --config vite.config.lib.ts && node ../../scripts/generate-browser-package-json.mjs .",
    "clean": "rm -rf dist",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@repo/shared-adapters": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:"
  }
}
